<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BSI Maslahat — Waqf ERP 2026</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#F0F2F5;color:#1C1C1E;font-size:14px}
:root{--G:#1D9E75;--Gl:#E8F7F2;--Gd:#0F6E56;--R:#E24B4A;--Rl:#FDEAEA;--AM:#F59E0B;--Al:#FEF3C7;--B:#3B82F6;--Bl:#EFF6FF;--PU:#8B5CF6;--Pl:#F5F3FF;--bd:#E4E4E7;--bg:#F0F2F5;--sur:#fff;--txt:#1C1C1E;--mu:#71717A;--lt:#A1A1AA}
.app{display:flex;height:100vh;overflow:hidden}
.sb{width:236px;background:var(--sur);border-right:1px solid var(--bd);display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto}
.sb-logo{padding:15px 14px;border-bottom:1px solid var(--bd);display:flex;align-items:center;gap:10px}
.sb-ic{width:32px;height:32px;background:var(--G);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;flex-shrink:0}
.sb-nm{font-size:13px;font-weight:600}.sb-sb{font-size:11px;color:var(--mu)}
.sb-nav{padding:8px 7px;flex:1}
.sb-sec{font-size:10px;font-weight:600;color:var(--lt);text-transform:uppercase;letter-spacing:.7px;padding:10px 8px 3px;margin-top:4px}
.ni{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:8px;cursor:pointer;color:var(--mu);font-size:13px;border:none;background:none;width:100%;text-align:left;transition:all .12s;font-family:inherit}
.ni:hover{background:#F4F4F5;color:var(--txt)}.ni.on{background:var(--Gl);color:var(--Gd);font-weight:600}
.ni i{font-size:15px;width:17px;flex-shrink:0}
.sn{padding-left:16px}.sn .ni{font-size:12px;padding:5px 9px}
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.topbar{padding:12px 22px;background:var(--sur);border-bottom:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;gap:12px}
.topbar-left{flex:1}.topbar h1{font-size:15px;font-weight:600}.topbar p{font-size:11px;color:var(--mu);margin-top:1px}
.topbar-right{display:flex;gap:7px;align-items:center;flex-shrink:0}
.content{flex:1;overflow-y:auto;padding:18px 22px}
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 13px;border-radius:8px;border:1px solid var(--bd);background:var(--sur);cursor:pointer;font-size:13px;font-weight:500;color:var(--txt);transition:all .12s;font-family:inherit}
.btn:hover{background:#F4F4F5}
.btn-g{background:var(--G);color:#fff;border-color:var(--G)}.btn-g:hover{background:var(--Gd)}
.btn-r{background:var(--Rl);color:#B91C1C;border-color:#FCA5A5}.btn-r:hover{background:#FCA5A5}
.btn-b{background:var(--Bl);color:#1D4ED8;border-color:#93C5FD}.btn-b:hover{background:#DBEAFE}
.btn-sm{padding:5px 10px;font-size:12px}.btn-xs{padding:3px 7px;font-size:11px}
.card{background:var(--sur);border:1px solid var(--bd);border-radius:12px;padding:15px 19px;margin-bottom:14px}
.ch{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px}
.ct{font-size:14px;font-weight:600}.cs2{font-size:11px;color:var(--mu)}
.mg{display:grid;grid-template-columns:repeat(auto-fit,minmax(145px,1fr));gap:10px;margin-bottom:16px}
.met{background:var(--sur);border:1px solid var(--bd);border-radius:10px;padding:12px 14px}
.ml{font-size:11px;color:var(--mu);margin-bottom:4px;font-weight:500}.mv{font-size:20px;font-weight:700;line-height:1.1}.ms{font-size:11px;color:var(--mu);margin-top:2px}
.met.g .mv{color:var(--G)}.met.r .mv{color:var(--R)}.met.b .mv{color:var(--B)}.met.a .mv{color:var(--AM)}.met.p .mv{color:var(--PU)}
.bdg{display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:20px;font-size:11px;font-weight:600}
.bG{background:var(--Gl);color:var(--Gd)}.bR{background:var(--Rl);color:#B91C1C}.bA{background:var(--Al);color:#92400E}.bB{background:var(--Bl);color:#1D4ED8}.bP{background:var(--Pl);color:#6D28D9}.bGR{background:#F4F4F5;color:#52525B}
.pb{height:6px;background:#E4E4E7;border-radius:4px;overflow:hidden}
.pf{height:100%;border-radius:4px}.pf.g{background:var(--G)}.pf.a{background:var(--AM)}.pf.r{background:var(--R)}
.tabs{display:flex;border-bottom:1px solid var(--bd);margin-bottom:14px;overflow-x:auto}
.tab{padding:8px 14px;font-size:13px;font-weight:500;color:var(--mu);border:none;background:none;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;font-family:inherit;white-space:nowrap;transition:all .12s}
.tab.on{color:var(--Gd);border-bottom-color:var(--G)}.tab:hover{color:var(--txt)}
.tw{overflow-x:auto}
table{width:100%;border-collapse:collapse}
th{text-align:left;padding:9px 11px;font-size:11px;font-weight:600;color:var(--mu);background:#FAFAFA;border-bottom:1px solid var(--bd);white-space:nowrap;cursor:pointer;user-select:none}
th:hover{background:#F0F0F0}
th .sort-icon{opacity:.4;font-size:10px;margin-left:3px}
th.asc .sort-icon::after{content:'↑';opacity:1}
th.desc .sort-icon::after{content:'↓';opacity:1}
td{padding:8px 11px;font-size:12px;border-bottom:1px solid #F4F4F5;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:#FAFAFA}
.tn{text-align:right;font-variant-numeric:tabular-nums}
.fg{display:flex;flex-direction:column;gap:4px}
.fl{font-size:11px;font-weight:600;color:var(--mu)}
.fi,.fse,.fta,.fdt{padding:7px 10px;border:1px solid var(--bd);border-radius:7px;font-size:13px;background:var(--sur);color:var(--txt);font-family:inherit;width:100%}
.fi:focus,.fse:focus,.fta:focus,.fdt:focus{outline:2px solid var(--G);outline-offset:1px}
.fta{resize:vertical;min-height:64px}
.gr2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.gr3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.gr4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:8px}
.ap{background:#FAFAFA;border:1px solid var(--bd);border-radius:12px;padding:15px;margin-bottom:14px;display:none}
.ap.open{display:block}
.apt{font-size:13px;font-weight:600;margin-bottom:12px}
.apf{display:flex;justify-content:flex-end;gap:8px;margin-top:12px}
.filters-bar{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;align-items:center;padding:10px 14px;background:var(--sur);border:1px solid var(--bd);border-radius:10px}
.filters-bar label{font-size:11px;font-weight:600;color:var(--mu);white-space:nowrap}
.fi-sm{padding:5px 8px;border:1px solid var(--bd);border-radius:6px;font-size:12px;background:var(--sur);color:var(--txt);font-family:inherit}
.kf{display:flex;gap:7px;margin-bottom:12px;flex-wrap:wrap}
.ki{padding:6px 10px;border:1px solid var(--bd);border-radius:7px;font-size:12px;background:var(--sur);color:var(--txt);font-family:inherit}
.kb{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.kc{background:#FAFAFA;border-radius:12px;padding:11px;min-height:80px}
.kch{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px}
.kct{font-size:13px;font-weight:600}
.kcn{background:var(--bd);color:var(--mu);border-radius:20px;padding:2px 7px;font-size:11px;font-weight:600}
.kcard{background:var(--sur);border:1px solid var(--bd);border-radius:9px;padding:11px;margin-bottom:7px;cursor:pointer;transition:all .12s}
.kcard:hover{border-color:var(--G)}
.kname{font-size:13px;font-weight:600;margin-bottom:4px;line-height:1.4}
.kprev{font-size:11px;color:var(--mu);line-height:1.5;margin-bottom:7px}
.kfoot{display:flex;gap:5px;flex-wrap:wrap}
.kdate{font-size:10px;color:var(--lt);display:flex;align-items:center;gap:3px;margin-top:4px}
.gw{overflow-x:auto}
.gt{min-width:660px}
.ghd{display:flex;padding-bottom:5px;border-bottom:1px solid var(--bd);margin-bottom:7px}
.glb{width:195px;flex-shrink:0;font-size:10px;font-weight:600;color:var(--mu)}
.gms{flex:1;display:grid;grid-template-columns:repeat(12,1fr)}
.gm{font-size:9px;color:var(--mu);text-align:center}
.grow{display:flex;align-items:center;margin-bottom:5px}
.grl{width:195px;flex-shrink:0;font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;padding-right:8px;cursor:pointer;color:var(--Gd)}
.grl:hover{text-decoration:underline}
.gtr{flex:1;height:18px;background:#F4F4F5;border-radius:3px;position:relative}
.gbar{position:absolute;top:1px;height:16px;border-radius:3px;display:flex;align-items:center;padding:0 5px;font-size:9px;color:#fff;font-weight:500}
.ag{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px}
.acard{background:var(--sur);border:1px solid var(--bd);border-radius:12px;padding:14px;transition:all .12s}
.acard:hover{border-color:var(--G)}
.aico{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px}
.ov{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:500;display:none;align-items:flex-start;justify-content:center;padding:36px 14px;overflow-y:auto}
.ov.open{display:flex}
.mbox{background:var(--sur);border-radius:14px;width:640px;max-width:100%;border:1px solid var(--bd)}
.mhd{padding:14px 18px;border-bottom:1px solid var(--bd);display:flex;gap:10px}
.mhc{flex:1}.mclose{background:none;border:none;cursor:pointer;color:var(--mu);font-size:20px;padding:2px;flex-shrink:0;line-height:1}
.mbody{padding:18px}
.alog{list-style:none;position:relative;padding-left:18px}
.alog::before{content:'';position:absolute;left:5px;top:0;bottom:0;width:1px;background:var(--bd)}
.ali{position:relative;padding-bottom:12px}
.adot{position:absolute;left:-16px;top:3px;width:12px;height:12px;border-radius:50%;background:var(--G);border:2px solid var(--sur)}
.adate{font-size:10px;color:var(--mu);margin-bottom:2px}.atext{font-size:13px;line-height:1.5}
.ie{border:1px solid transparent;background:transparent;font-size:inherit;font-weight:inherit;color:inherit;padding:2px 5px;border-radius:4px;font-family:inherit;outline:none}
.ie:hover{background:#F4F4F5;border-color:var(--bd)}.ie:focus{background:#F4F4F5;border-color:var(--G)}
.page{display:none}.page.active{display:block}
.bc{display:flex;gap:5px;align-items:flex-end;height:100px}
.bi{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px}
.bfill{width:100%;border-radius:3px 3px 0 0;min-height:4px}
.blb{font-size:9px;color:var(--mu);text-align:center;line-height:1.2;max-width:52px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.bval{font-size:9px;color:var(--mu);font-weight:600}
.info-box{font-size:12px;color:var(--mu);margin-bottom:12px;padding:10px 12px;background:var(--Gl);border-radius:8px;display:flex;gap:8px;align-items:flex-start}
.info-box i{color:var(--G);font-size:16px;flex-shrink:0;margin-top:1px}
/* Progress bar card */
.prog-card{background:var(--sur);border:1px solid var(--bd);border-radius:10px;padding:14px 16px;margin-bottom:10px}
.prog-card-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px}
.prog-card-title{font-size:13px;font-weight:600}
.prog-card-meta{font-size:11px;color:var(--mu);margin-top:2px}
.prog-card-nums{display:flex;gap:16px;margin-bottom:6px}
.prog-card-num{font-size:12px}.prog-card-num span{font-weight:600}
/* Himpun compact table view */
.himpun-compact th,.himpun-compact td{padding:7px 10px;font-size:12px}
</style>
</head>
<body>
<div class="app">
<aside class="sb">
  <div class="sb-logo">
    <div class="sb-ic"><i class="ti ti-building-mosque"></i></div>
    <div><div class="sb-nm">BSI Maslahat</div><div class="sb-sb">Waqf Group ERP</div></div>
  </div>
  <nav class="sb-nav">
    <div class="sb-sec">Overview</div>
    <button class="ni on" onclick="go('dashboard')"><i class="ti ti-layout-dashboard"></i>Dashboard</button>
    <div class="sb-sec">Project Tracker</div>
    <button class="ni" onclick="go('tracker','')"><i class="ti ti-kanban"></i>Semua Project</button>
    <div class="sn">
      <button class="ni" onclick="go('tracker','Rumah Quran')"><i class="ti ti-book"></i>Rumah Quran</button>
      <button class="ni" onclick="go('tracker','Masjid BSI')"><i class="ti ti-building-mosque"></i>Masjid BSI</button>
      <button class="ni" onclick="go('tracker','Fundraising')"><i class="ti ti-heart-handshake"></i>Fundraising</button>
      <button class="ni" onclick="go('tracker','Pengelolaan Aset')"><i class="ti ti-briefcase"></i>Pengelolaan Aset</button>
    </div>
    <div class="sb-sec">Data &amp; Target</div>
    <button class="ni" onclick="go('himpun')"><i class="ti ti-trending-up"></i>Penghimpunan</button>
    <button class="ni" onclick="go('salprog')"><i class="ti ti-send"></i>Penyaluran Program</button>
    <button class="ni" onclick="go('saluang')"><i class="ti ti-currency-dollar"></i>Penyaluran Wakaf Uang</button>
    <button class="ni" onclick="go('salmelalui')"><i class="ti ti-droplet"></i>Penyaluran Wakaf Melalui Uang</button>
    <button class="ni" onclick="go('imbalhasil')"><i class="ti ti-chart-line"></i>Penyaluran Imbal Hasil</button>
    <button class="ni" onclick="go('pengelolaan')"><i class="ti ti-wallet"></i>Pengelolaan Wakaf Uang</button>
    <button class="ni" onclick="go('aset')"><i class="ti ti-building-estate"></i>Kepemilikan Aset</button>
  </nav>
</aside>

<div class="main">
  <div class="topbar">
    <div class="topbar-left"><h1 id="ptitle">Dashboard</h1><p id="psub">BSI Maslahat · Waqf Group</p></div>
    <div class="topbar-right">
      <select class="fi-sm" id="global-year" onchange="applyGlobalYear()" style="width:90px">
        <option value="">Semua Tahun</option>
        <option value="2024">2024</option>
        <option value="2025">2025</option>
        <option value="2026" selected>2026</option>
      </select>
      <button class="btn btn-sm" id="btn-export" onclick="handleExport()"><i class="ti ti-download"></i>Export</button>
      <button class="btn btn-sm btn-g" onclick="handleAdd()"><i class="ti ti-plus"></i>Tambah</button>
    </div>
  </div>
  <div class="content">

<!-- DASHBOARD -->
<div id="pg-dashboard" class="page active">
  <div class="mg" id="dm"></div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px">
    <div class="card">
      <div class="ch"><div><div class="ct">Target Penghimpunan vs Realisasi</div><div class="cs2" id="dash-year-label">2026</div></div></div>
      <div id="dash-target-h"></div>
    </div>
    <div class="card">
      <div class="ch"><div><div class="ct">Target Penyaluran Program vs Realisasi</div><div class="cs2" id="dash-year-label2">2026</div></div></div>
      <div id="dash-target-sp"></div>
    </div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
    <div class="card"><div class="ch"><div><div class="ct">Penghimpunan per Program</div><div class="cs2">Top 6 program</div></div></div><div class="bc" id="dbar"></div></div>
    <div class="card"><div class="ch"><div class="ct">Progress per Divisi (Project)</div></div><div id="ddiv"></div></div>
  </div>
  <div class="card" style="margin-top:14px"><div class="ch"><div class="ct">Project On Hold — Perlu Tindak Lanjut</div><span class="bdg bR" id="dhbadge">0</span></div><div id="dhold"></div></div>
</div>

<!-- TRACKER -->
<div id="pg-tracker" class="page">
  <div class="ap" id="ap-proj">
    <div class="apt">Tambah Project Baru</div>
    <div class="gr2"><div class="fg"><label class="fl">Nama Project</label><input class="fi" id="np-n" placeholder="Nama project..."></div><div class="fg"><label class="fl">Divisi</label><select class="fse" id="np-d"><option>Rumah Quran</option><option>Masjid BSI</option><option>Fundraising</option><option>Pengelolaan Aset</option><option>Program</option></select></div></div>
    <div class="gr2" style="margin-top:9px"><div class="fg"><label class="fl">PIC</label><input class="fi" id="np-p" placeholder="Nama PIC..."></div><div class="fg"><label class="fl">Status</label><select class="fse" id="np-s"><option>On Going</option><option>On Hold</option><option>Done</option></select></div></div>
    <div class="gr2" style="margin-top:9px">
      <div class="fg"><label class="fl">Bulan Mulai</label><select class="fse" id="np-bm"><option value="1">Jan</option><option value="2">Feb</option><option value="3">Mar</option><option value="4">Apr</option><option value="5">Mei</option><option value="6">Jun</option><option value="7">Jul</option><option value="8">Agu</option><option value="9">Sep</option><option value="10">Okt</option><option value="11">Nov</option><option value="12">Des</option></select></div>
      <div class="fg"><label class="fl">Bulan Selesai</label><select class="fse" id="np-bs"><option value="1">Jan</option><option value="2">Feb</option><option value="3">Mar</option><option value="4">Apr</option><option value="5">Mei</option><option value="6">Jun</option><option value="7">Jul</option><option value="8">Agu</option><option value="9">Sep</option><option value="10">Okt</option><option value="11">Nov</option><option value="12" selected>Des</option></select></div>
    </div>
    <div class="fg" style="margin-top:9px"><label class="fl">Catatan Awal</label><textarea class="fta" id="np-note" placeholder="Deskripsi..."></textarea></div>
    <div class="apf"><button class="btn btn-sm" onclick="closeAP('ap-proj')">Batal</button><button class="btn btn-sm btn-g" onclick="addProject()"><i class="ti ti-check"></i>Simpan</button></div>
  </div>
  <div class="kf">
    <select class="ki" id="fd" onchange="renderK()"><option value="">Semua Divisi</option><option>Rumah Quran</option><option>Masjid BSI</option><option>Fundraising</option><option>Pengelolaan Aset</option><option>Program</option></select>
    <select class="ki" id="fp" onchange="renderK()"><option value="">Semua PIC</option><option>Kays</option><option>Azizyah</option><option>Dodi</option></select>
    <select class="ki" id="fs" onchange="renderK()"><option value="">Semua Status</option><option>On Going</option><option>On Hold</option><option>Done</option></select>
    <input class="ki" id="fq" placeholder="Cari project..." oninput="renderK()">
    <div style="margin-left:auto;display:flex;gap:5px">
      <button class="btn btn-sm" onclick="setTV('kanban')"><i class="ti ti-layout-kanban"></i>Kanban</button>
      <button class="btn btn-sm" onclick="setTV('gantt')"><i class="ti ti-timeline"></i>Timeline</button>
    </div>
  </div>
  <div id="vk"><div class="kb" id="kboard"></div></div>
  <div id="vg" style="display:none"><div class="card"><div class="gw"><div class="gt" id="gantt"></div></div></div></div>
</div>

<!-- PENGHIMPUNAN -->
<div id="pg-himpun" class="page">
  <div class="ap" id="ap-himpun">
    <div class="apt">Tambah Program Penghimpunan</div>
    <div class="gr2"><div class="fg"><label class="fl">Nama Program</label><input class="fi" id="nh-p" placeholder="Wakaf Sumur, Wakaf Masjid..."></div><div class="fg"><label class="fl">Channel</label><input class="fi" id="nh-c" placeholder="BYOND / digital / Rekening..."></div></div>
    <div class="apf"><button class="btn btn-sm" onclick="closeAP('ap-himpun')">Batal</button><button class="btn btn-sm btn-g" onclick="addHimpunProg()"><i class="ti ti-check"></i>Buat Program</button></div>
  </div>
  <div class="mg" id="hm"></div>
  <div class="filters-bar">
    <label>Tahun:</label><select class="fi-sm" id="hf-year" onchange="renderH()"><option value="">Semua</option><option value="2024">2024</option><option value="2025">2025</option><option value="2026">2026</option><option value="2027">2027</option></select>
    <label style="margin-left:8px">Bulan:</label><select class="fi-sm" id="hf-month" onchange="renderH()"><option value="">Semua</option><option value="01">Januari</option><option value="02">Februari</option><option value="03">Maret</option><option value="04">April</option><option value="05">Mei</option><option value="06">Juni</option><option value="07">Juli</option><option value="08">Agustus</option><option value="09">September</option><option value="10">Oktober</option><option value="11">November</option><option value="12">Desember</option></select>
    <label style="margin-left:8px">Channel:</label><select class="fi-sm" id="hf-ch" onchange="renderH()"><option value="">Semua</option></select>
    <label style="margin-left:8px">Tampilan:</label>
    <button class="btn btn-xs" id="hview-compact" onclick="setHView('compact')"><i class="ti ti-table"></i>Kompak</button>
    <button class="btn btn-xs on" id="hview-detail" onclick="setHView('detail')"><i class="ti ti-list"></i>Detail</button>
    <div style="margin-left:auto;font-size:12px;color:var(--mu)">Total filtered: <strong id="hf-total">Rp 0</strong></div>
  </div>
  <div class="tabs">
