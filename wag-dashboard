function go(pg,fd){
  CUR=pg;
  document.querySelectorAll('.page').forEach(function(el){el.classList.remove('active');});
  document.querySelectorAll('.ni').forEach(function(el){el.classList.remove('on');});
  var pel=sg('pg-'+pg);if(pel)pel.classList.add('active');
  var info=PI[pg]||{t:pg,s:''};sg('ptitle').textContent=info.t;sg('psub').textContent=info.s;
  if(pg==='tracker'){if(fd!==undefined)sg('fd').value=fd||'';renderK();}
  if(pg==='himpun')renderH();
  if(pg==='salprog')renderSP();
  if(pg==='saluang')renderSU();
  if(pg==='salmelalui')renderSM();
  if(pg==='imbalhasil')renderIH();
  if(pg==='pengelolaan')renderPW();
  if(pg==='aset')renderA();
  if(pg==='dashboard')renderD();
}
