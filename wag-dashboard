// ==================== EXPORT ====================
function handleExport(){
  var format=window.confirm('Export sebagai CSV?\n(OK = CSV, Cancel = tampilkan ringkasan teks)')?'csv':'text';
  var data=[];
  var name=CUR;
  if(CUR==='himpun'){
    data.push('Program,Channel,Periode,Nilai (Rp)');
    H.forEach(function(r){r.months.forEach(function(m){data.push([r.p,r.c,m.d,m.v].join(','));});});
    name='penghimpunan';
  } else if(CUR==='salprog'){
    data.push('Program,Sumber Dana,Divisi,Periode,Realisasi (Rp),Target (Rp)');
    SP.forEach(function(r){r.months.forEach(function(m){data.push([r.p,r.s,r.d,m.d,m.v,r.t].join(','));});});
    name='penyaluran_program';
  } else if(CUR==='saluang'){
    data.push('Program,Jenis,Nominal (Rp),Penerima Manfaat,Tgl Mulai,Tgl Berakhir,Keterangan');
    SU.forEach(function(r){data.push([r.p,r.j,r.n,r.pm,r.tm,r.ta,r.k].join(','));});
    name='penyaluran_wakaf_uang';
  } else if(CUR==='salmelalui'){
    data.push('Program,Jenis,Lokasi,Nominal (Rp),Penerima Manfaat,Tanggal,Keterangan');
    SM.forEach(function(r){data.push([r.p,r.j,r.l,r.n,r.pm,r.tgl,r.k].join(','));});
    name='penyaluran_wakaf_melalui_uang';
  } else if(CUR==='imbalhasil'){
    data.push('Program,Sumber Dana,Nominal (Rp),Penerima Manfaat,Tanggal,Keterangan');
    IH.forEach(function(r){data.push([r.p,r.s,r.n,r.pm,r.tgl,r.k].join(','));});
    name='imbal_hasil';
  } else if(CUR==='pengelolaan'){
    data.push('Program,Sumber Dana,Nominal (Rp),Penerima Manfaat,Tanggal,Keterangan');
    PW.forEach(function(r){data.push([r.p,r.s,r.n,r.pm,r.tgl,r.k].join(','));});
    name='pengelolaan_wakaf_uang';
  } else if(CUR==='aset'){
    data.push('Nama Aset,Wakif,Lokasi,Peruntukan,Status,Tipe,Nilai (Rp),Tahun');
    A.forEach(function(r){data.push([r.nama,r.wakif,r.lokasi,r.pu,r.status,r.tipe,r.nilai,r.tahun].join(','));});
    name='kepemilikan_aset';
  } else if(CUR==='tracker'){
    data.push('Nama Project,Divisi,PIC,Status,Bulan Mulai,Bulan Selesai');
    P.forEach(function(r){data.push([r.name,r.divisi,r.pic,r.status,r.bm,r.bs].join(','));});
    name='project_tracker';
  } else {
    alert('Export tersedia di masing-masing halaman Data & Target atau Project Tracker.');
    return;
  }
  if(data.length<=1){alert('Tidak ada data untuk di-export.');return;}
  var csv='\uFEFF'+data.join('\n');
  var blob=new Blob([csv],{type:'text/csv;charset=utf-8;'});
  var url=URL.createObjectURL(blob);
  var a=document.createElement('a');
  a.href=url;a.download=name+'_'+new Date().toISOString().split('T')[0]+'.csv';
  document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(url);
}

