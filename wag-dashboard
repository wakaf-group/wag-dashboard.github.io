function himpunFiltered(yr){
  var tot=0;
  H.forEach(function(r){r.months.forEach(function(m){if(!yr||getYear(m.d)===yr)tot+=m.v;});});
  return tot;
}
function spFiltered(yr){
  var tot=0;
  SP.forEach(function(r){r.months.forEach(function(m){if(!yr||getYear(m.d)===yr)tot+=m.v;});});
  return tot;
}
